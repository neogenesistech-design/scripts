function deleteCacheFiles() {
    Java.perform(() => {
        try {
            const ActivityThread = Java.use("android.app.ActivityThread");
            const context = ActivityThread.currentApplication().getApplicationContext();
            const pkgName = context.getPackageName();
            const File = Java.use("java.io.File");
            const path = Java.use("android.os.Environment").getExternalStorageDirectory().getAbsolutePath() + "/Android/data/" + pkgName + "/";
            const EXCLUDE_PATHS = ["files/levels/images/classiciphone", "saved_functions.txt"];
            const targetDir = File.$new(path);
            if (!targetDir.exists() || !targetDir.isDirectory()) return;
            const files = targetDir.listFiles();
            for (let i = 0; i < files.length; i++) {
                try {
                    const f = files[i];
                    let exclude = false;
                    for (let k = 0; k < EXCLUDE_PATHS.length; k++) if (f.getAbsolutePath().includes(EXCLUDE_PATHS[k])) exclude = true;
                    if (exclude) continue;
                    if (f.isDirectory()) deleteRecursive(f, EXCLUDE_PATHS); else f.delete();
                } catch (err) {}
            }
        } catch (e) {}
    });
}
function deleteRecursive(f, e) { try { const sub = f.listFiles(); if (sub) for (let j = 0; j < sub.length; j++) { let ex = false; for (let k = 0; k < e.length; k++) if (sub[j].getAbsolutePath().includes(e[k])) ex = true; if (ex) continue; if (sub[j].isDirectory()) deleteRecursive(sub[j], e); else sub[j].delete(); } f.delete(); } catch (err) {} }
deleteCacheFiles();

setTimeout(() => {
    // --- VARIÁVEIS DE CONTROLE ---
    let projectileTypeOverride = 3; // O padrão que vimos no código (0x3)
    let isOverrideActive = false;

    // --- ENDEREÇOS ---
    const activeplayer = Module.findExportByName("libqplay.so", "dkCHgaGRiF").readPointer();
    const spawnFuncPtr = Module.findExportByName("libqplay.so", "_ZN10W6NzgawMJy10UwflwasGuPEv");
    const launchProjectile = spawnFuncPtr ? new NativeFunction(spawnFuncPtr, "void", ["pointer"]) : null;

    // Construtor que você enviou
    const constructorPtr = Module.findExportByName("libqplay.so", "_ZN10fJ8VgaKXwR10fJ8VgaKXwRP10zF9VgaBKxR");

    // --- HOOK NO CONSTRUTOR (A MÁGICA DA TROCA) ---
    if (constructorPtr) {
        Interceptor.attach(constructorPtr, {
            onLeave: function(retval) {
                if (isOverrideActive) {
                    const obj = retval; // O 'this' retornado pelo construtor
                    // No código: this[0xe] = 0x3. No Frida, offsets em objetos C++ 
                    // dependem do alinhamento. Vamos tentar o offset 0xe diretamente.
                    try {
                        obj.add(0xe).writeU8(projectileTypeOverride);
                    } catch(e) {
                        console.log("Erro ao sobrescrever tipo: " + e);
                    }
                }
            }
        });
    }

    // --- UI E CONTROLE ---
    let smartListLogs = [], currentTargetIndex = 0, interceptedData = {}, scanMode = 0, saveCounter = 1;

    Java.perform(function () {
        Java.scheduleOnMainThread(function () {
            const classLoader = getgetClassLoader(), mainActivity = getMainActivity(classLoader);
            const Gravity = classLoader.Gravity;
            const PADDING = pixelDensityToPixels(mainActivity, 8), MARGIN = pixelDensityToPixels(mainActivity, 2);

            // --- PAINEL TOP RIGHT ---
            const trRoot = classLoader.LinearLayout.$new(mainActivity); trRoot.setOrientation(0); trRoot.setGravity(Gravity.RIGHT | Gravity.TOP); trRoot.setPadding(0, PADDING*4, 0, 0);
            const lpBtn = classLoader.LinearLayout_LayoutParams.$new(-2,-2); lpBtn.setMargins(MARGIN, MARGIN, MARGIN, MARGIN);

            // BOTÃO: DISPARAR (Usa o override se ativo)
            const fireBtn = classLoader.TextView.$new(mainActivity);
            fireBtn.setText(classLoader.String.$new("[ DISPARAR ]"));
            fireBtn.setBackgroundColor(classLoader.Color.parseColor("#CCFF4500"));
            fireBtn.setTextColor(-1); fireBtn.setPadding(PADDING, PADDING, PADDING, PADDING); fireBtn.setLayoutParams(lpBtn);
            fireBtn.setOnClickListener(Java.registerClass({
                name: "FireBtn", implements: [Java.use("android.view.View$OnClickListener")],
                methods: { onClick(v) { if (launchProjectile) launchProjectile(activeplayer); } }
            }).$new());
            trRoot.addView(fireBtn);

            // BOTÃO: TIPO++
            const typeBtn = classLoader.TextView.$new(mainActivity);
            typeBtn.setText(classLoader.String.$new("Tipo: " + projectileTypeOverride));
            typeBtn.setBackgroundColor(-16777216); typeBtn.setTextColor(-1); typeBtn.setPadding(PADDING, PADDING, PADDING, PADDING); typeBtn.setLayoutParams(lpBtn);
            typeBtn.setOnClickListener(Java.registerClass({
                name: "TypeBtn", implements: [Java.use("android.view.View$OnClickListener")],
                methods: { onClick(v) { 
                    projectileTypeOverride++; 
                    if(projectileTypeOverride > 20) projectileTypeOverride = 1; // Cicla os IDs
                    v.setText(classLoader.String.$new("Tipo: " + projectileTypeOverride));
                } }
            }).$new());
            trRoot.addView(typeBtn);

            // --- GAVETA INFERIOR ---
            const mainBar = classLoader.LinearLayout.$new(mainActivity); mainBar.setOrientation(1); mainBar.setVisibility(8);
            const row1 = classLoader.LinearLayout.$new(mainActivity); row1.setOrientation(0); row1.setGravity(Gravity.CENTER); mainBar.addView(row1);

            const addToggle = (r, t, on, off) => {
                const b = classLoader.TextView.$new(mainActivity); let isOn = false; b.setText(classLoader.String.$new(t)); b.setBackgroundColor(-16777216); b.setTextColor(-1); b.setPadding(PADDING,PADDING,PADDING,PADDING); b.setLayoutParams(lpBtn);
                b.setOnClickListener(Java.registerClass({ name: "B"+Math.random().toString(36).substring(7), implements:[Java.use("android.view.View$OnClickListener")], methods:{ onClick(v){ isOn=!isOn; v.setBackgroundColor(isOn?classLoader.Color.parseColor("#80008000"):-16777216); if(isOn)on(); else off(); } } }).$new());
                r.addView(b);
            };

            addToggle(row1, "SWAPPER ON", ()=>{isOverrideActive=true;}, ()=>{isOverrideActive=false;});
            addToggle(row1, "SCAN", ()=>{scanMode=1; smartListLogs=[]; setTimeout(()=>{if(scanMode===1)scanMode=2;},3000);}, ()=>{scanMode=0;});

            // Re-adiciona as outras views...
            const bottomLayout = classLoader.LinearLayout.$new(mainActivity); bottomLayout.setGravity(Gravity.BOTTOM | Gravity.CENTER_HORIZONTAL); bottomLayout.addView(mainBar);
            const topLayout = classLoader.LinearLayout.$new(mainActivity); topLayout.setGravity(Gravity.TOP | Gravity.LEFT);
            const menuToggle = classLoader.TextView.$new(mainActivity); menuToggle.setText(classLoader.String.$new("[ Menu ]")); menuToggle.setBackgroundColor(-16777216); menuToggle.setTextColor(-1); menuToggle.setPadding(PADDING,PADDING,PADDING,PADDING);
            let menuOn = false; menuToggle.setOnClickListener(Java.registerClass({ name: "M", implements:[Java.use("android.view.View$OnClickListener")], methods:{ onClick(v){ menuOn=!menuOn; mainBar.setVisibility(menuOn?0:8); v.setBackgroundColor(menuOn?classLoader.Color.parseColor("#80008000"):-16777216); } } }).$new());
            topLayout.addView(menuToggle);

            mainActivity.addContentView(trRoot, classLoader.LinearLayout_LayoutParams.$new(-1,-1));
            mainActivity.addContentView(topLayout, classLoader.LinearLayout_LayoutParams.$new(-1,-1));
            mainActivity.addContentView(bottomLayout, classLoader.LinearLayout_LayoutParams.$new(-1,-1));
        });
    });

    function getgetClassLoader(){ return { Gravity: Java.use("android.view.Gravity"), TextView: Java.use("android.widget.TextView"), LinearLayout: Java.use("android.widget.LinearLayout"), LinearLayout_LayoutParams: Java.use("android.widget.LinearLayout$LayoutParams"), Color: Java.use("android.graphics.Color"), ActivityThread: Java.use("android.app.ActivityThread"), View: Java.use("android.view.View"), String: Java.use("java.lang.String") }; }
    function getMainActivity(cl){ return Java.cast(cl.ActivityThread.sCurrentActivityThread.value.mActivities.value.valueAt(0), Java.use("android.app.ActivityThread$ActivityClientRecord")).activity.value; }
    function pixelDensityToPixels(c, dp){ return parseInt(dp * c.getResources().getDisplayMetrics().density.value); }
}, 8000);
