function deleteCacheFiles() {
    Java.perform(() => {
        try {
            const ActivityThread = Java.use("android.app.ActivityThread");
            const context = ActivityThread.currentApplication().getApplicationContext();
            const pkgName = context.getPackageName();
            const File = Java.use("java.io.File");
            const path = Java.use("android.os.Environment").getExternalStorageDirectory().getAbsolutePath() + "/Android/data/" + pkgName + "/";
            const EXCLUDE_PATHS = ["files/levels/images/classiciphone", "saved_functions.txt"];
            const targetDir = File.$new(path);
            if (!targetDir.exists() || !targetDir.isDirectory()) return;
            const files = targetDir.listFiles();
            for (let i = 0; i < files.length; i++) {
                try {
                    const f = files[i];
                    let exclude = false;
                    for (let k = 0; k < EXCLUDE_PATHS.length; k++) if (f.getAbsolutePath().includes(EXCLUDE_PATHS[k])) exclude = true;
                    if (exclude) continue;
                    if (f.isDirectory()) deleteRecursive(f, EXCLUDE_PATHS); else f.delete();
                } catch (err) {}
            }
        } catch (e) {}
    });
}
function deleteRecursive(f, e) { try { const sub = f.listFiles(); if (sub) for (let j = 0; j < sub.length; j++) { let ex = false; for (let k = 0; k < e.length; k++) if (sub[j].getAbsolutePath().includes(e[k])) ex = true; if (ex) continue; if (sub[j].isDirectory()) deleteRecursive(sub[j], e); else sub[j].delete(); } f.delete(); } catch (err) {} }
