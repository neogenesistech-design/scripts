(function() {
    // Usamos um delay menor para não perder o timing da lib
    setTimeout(() => {
        const mod = Process.findModuleByName("libqplay.so");
        if (!mod) return;

        console.log("[🛡️] Radar Mobile Ativo");

        // Cache de endereços para não re-buscar
        const addrSetVar = mod.findExportByName("_ZN9TGraalVar11setVarValueEPS_"); // Nome mangled comum
        const addrGetPlayer = mod.findExportByName("_ZN7TClient19getGlobalPlayerByIDEi");
        const addrDestructor = mod.findExportByName("_ZN13TServerPlayerD1Ev");

        if (!addrGetPlayer || !addrSetVar) {
            console.log("[!] Falha ao localizar funções essenciais.");
            return;
        }

        const setVarValue = new NativeFunction(addrSetVar, "void", ["pointer", "pointer"]);
        const cleanPtr = (p) => ptr(p).and(ptr("0x00007FFFFFFFFFFF"));
        const accRegex = /^(pc\:|graal\d+|guest.*)/;
        
        // Usamos um objeto simples em vez de Map para economizar memória no gadget
        const players = {}; 

        function readTString(address) {
            try {
                const pstr = address.readPointer();
                if (pstr.isNull()) return "---";
                const cPtr = cleanPtr(pstr);
                const len = cPtr.readInt();
                if (len > 0 && len < 50) return cPtr.add(8).readCString(len);
            } catch (e) {}
            return "---";
        }

        function applyEffect(pPtr, isAdmin) {
            try {
                const p = cleanPtr(pPtr);
                const tstring_ptr = p.add(0x318).readPointer();
                if (tstring_ptr.isNull()) return;
                
                const cmd = isAdmin ? "alpha=1.0\0zoom=1.4\0" : "alpha=0.5\0zoom=1.0\0";
                const cTstring = cleanPtr(tstring_ptr);
                cTstring.add(8).writeUtf8String(cmd);
                cTstring.writeInt(cmd.length);
                
                setVarValue(p, p.add(0x318));
            } catch(e) {}
        }

        // Hook principal - Otimizado para não processar strings toda vez
        Interceptor.attach(addrGetPlayer, {
            onLeave: function(retval) {
                if (retval.isNull()) return;
                const pStr = cleanPtr(retval).toString();
                
                if (players[pStr] === undefined) {
                    const acc = readTString(cleanPtr(retval).add(936)).toLowerCase();
                    if (acc === "---") return;
                    
                    const isAdmin = !accRegex.test(acc);
                    players[pStr] = isAdmin;
                    
                    if (isAdmin) console.log("🚨 ADMIN: " + acc);
                    applyEffect(retval, isAdmin);
                }
            }
        });

        // Limpeza automática ao sair da tela
        if (addrDestructor) {
            Interceptor.attach(addrDestructor, {
                onEnter: function(args) {
                    delete players[cleanPtr(args[0]).toString()];
                }
            });
        }

    }, 5000); // 5 segundos costumam ser suficientes se o loader já demora
})();
