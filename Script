Java.perform(function() {
    console.log("[*] Script remoto carregado com sucesso!");

    // Usamos o scheduleOnMainThread porque Toasts precisam rodar na thread de interface
    Java.scheduleOnMainThread(function() {
        var Toast = Java.use("android.widget.Toast");
        var String = Java.use("java.lang.String");
        var ActivityThread = Java.use("android.app.ActivityThread");
        
        // Obtém o contexto da aplicação de forma dinâmica
        var context = ActivityThread.currentApplication().getApplicationContext();
        
        // Mensagem de sucesso
        var message = String.$new("Hello World! Frida Injetado com Sucesso!");
        
        // Exibe o Toast (0 = Short, 1 = Long)
        var toast = Toast.makeText(context, message, 1);
        toast.show();
        
        console.log("[*] Toast exibido no jogo!");
    });
});
