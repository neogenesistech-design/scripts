let updateVirtualLog = function(msg) { console.log(msg); };

// --- 1. FASE VISUAL ---
Java.perform(function () {
    function getClassLoader() {
        return {
            Gravity: Java.use("android.view.Gravity"),
            TextView: Java.use("android.widget.TextView"),
            LinearLayout: Java.use("android.widget.LinearLayout"),
            LinearLayout_LayoutParams: Java.use("android.widget.LinearLayout$LayoutParams"),
            FrameLayout: Java.use("android.widget.FrameLayout"),
            FrameLayout_LayoutParams: Java.use("android.widget.FrameLayout$LayoutParams"),
            ScrollView: Java.use("android.widget.ScrollView"),
            Color: Java.use("android.graphics.Color"),
            ActivityThread: Java.use("android.app.ActivityThread"),
            View_OnTouchListener: Java.use("android.view.View$OnTouchListener"),
            MotionEvent: Java.use("android.view.MotionEvent"),
            String: Java.use("java.lang.String"),
            View: Java.use("android.view.View"),
            DisplayMetrics: Java.use("android.util.DisplayMetrics"),
            GradientDrawable: Java.use("android.graphics.drawable.GradientDrawable")
        };
    }

    function getMainActivity(classLoader) { 
        const activityThread = classLoader.ActivityThread.sCurrentActivityThread.value;
        const activityClientRecord = Java.cast(activityThread.mActivities.value.valueAt(0), Java.use("android.app.ActivityThread$ActivityClientRecord"));
        return activityClientRecord.activity.value;
    }

    Java.scheduleOnMainThread(function () {
        try {
            const classLoader = getClassLoader();
            const mainActivity = getMainActivity(classLoader);
            const metrics = mainActivity.getResources().getDisplayMetrics();
            const screenHeight = metrics.heightPixels.value;

            const CONF = {
                letraIcone: "T",
                menuLargura: 600,
                alturaMenu: Math.round(screenHeight * 0.45),
                corFundoMenu: "#F2050505",
                corBorda: "#00FF00"
            };

            const rootLayout = classLoader.FrameLayout.$new(mainActivity);
            const dragContainer = classLoader.LinearLayout.$new(mainActivity);
            dragContainer.setOrientation(classLoader.LinearLayout.VERTICAL.value);
            
            const containerParams = classLoader.FrameLayout_LayoutParams.$new(-2, -2);
            containerParams.gravity.value = classLoader.Gravity.TOP.value | classLoader.Gravity.LEFT.value;
            containerParams.leftMargin.value = 50;
            containerParams.topMargin.value = 300;
            dragContainer.setLayoutParams(containerParams);

            const floatIcon = classLoader.TextView.$new(mainActivity);
            floatIcon.setText(classLoader.String.$new(CONF.letraIcone));
            floatIcon.setTextColor(classLoader.Color.WHITE.value);
            floatIcon.setTextSize(22.0); 
            floatIcon.setGravity(classLoader.Gravity.CENTER.value);
            const iconBg = classLoader.GradientDrawable.$new();
            iconBg.setShape(1); 
            iconBg.setColor(classLoader.Color.parseColor("#CC000000")); 
            iconBg.setStroke(3, classLoader.Color.parseColor(CONF.corBorda)); 
            floatIcon.setBackground(iconBg);
            dragContainer.addView(floatIcon, classLoader.LinearLayout_LayoutParams.$new(100, 100));

            const menuLayout = classLoader.LinearLayout.$new(mainActivity);
            menuLayout.setOrientation(classLoader.LinearLayout.VERTICAL.value);
            const menuBg = classLoader.GradientDrawable.$new();
            menuBg.setCornerRadius(20.0); 
            menuBg.setColor(classLoader.Color.parseColor(CONF.corFundoMenu)); 
            menuBg.setStroke(3, classLoader.Color.parseColor(CONF.corBorda)); 
            menuLayout.setBackground(menuBg);
            menuLayout.setPadding(20, 20, 20, 20); 
            menuLayout.setVisibility(classLoader.View.VISIBLE.value); 

            const logTitle = classLoader.TextView.$new(mainActivity);
            logTitle.setText(classLoader.String.$new("TERMINATOR SYSTEM LOGS"));
            logTitle.setTextColor(classLoader.Color.parseColor(CONF.corBorda));
            menuLayout.addView(logTitle);

            const logScroll = classLoader.ScrollView.$new(mainActivity);
            const logText = classLoader.TextView.$new(mainActivity);
            logText.setText(classLoader.String.$new("[*] UI Pronta. Aguardando 16s...\n"));
            logText.setTextColor(classLoader.Color.WHITE.value);
            logText.setTextSize(10.0);
            logScroll.addView(logText);
            menuLayout.addView(logScroll, classLoader.LinearLayout_LayoutParams.$new(-1, CONF.alturaMenu));

            updateVirtualLog = function(msg) {
                Java.scheduleOnMainThread(() => {
                    let current = logText.getText().toString();
                    let lines = current.split('\n');
                    if (lines.length > 25) lines.shift();
                    lines.push("[#] " + msg);
                    logText.setText(classLoader.String.$new(lines.join('\n')));
                    logScroll.post(Java.registerClass({
                        name: "com.term.Scroll_" + Math.random().toString(36).substr(2),
                        implements: [Java.use("java.lang.Runnable")],
                        methods: { run: function() { logScroll.fullScroll(130); } }
                    }).$new());
                });
            };

            let iX=0, iY=0, itX=0, itY=0;
            floatIcon.setOnTouchListener(Java.registerClass({
                name: "com.term.DragHandler",
                implements: [classLoader.View_OnTouchListener],
                methods: {
                    onTouch: function (v, event) {
                        const action = event.getAction();
                        if (action === classLoader.MotionEvent.ACTION_DOWN.value) {
                            iX = containerParams.leftMargin.value; iY = containerParams.topMargin.value;
                            itX = event.getRawX(); itY = event.getRawY();
                        } else if (action === classLoader.MotionEvent.ACTION_MOVE.value) {
                            containerParams.leftMargin.value = iX + Math.round(event.getRawX() - itX);
                            containerParams.topMargin.value = iY + Math.round(event.getRawY() - itY);
                            dragContainer.setLayoutParams(containerParams);
                        } else if (action === classLoader.MotionEvent.ACTION_UP.value) {
                            if (Math.abs(event.getRawX() - itX) < 15) {
                                const vis = menuLayout.getVisibility() === classLoader.View.VISIBLE.value;
                                menuLayout.setVisibility(vis ? classLoader.View.GONE.value : classLoader.View.VISIBLE.value);
                            }
                        }
                        return true;
                    }
                }
            }).$new());

            dragContainer.addView(menuLayout, classLoader.LinearLayout_LayoutParams.$new(CONF.menuLargura, -2));
            rootLayout.addView(dragContainer);
            mainActivity.addContentView(rootLayout, classLoader.FrameLayout_LayoutParams.$new(-1, -1));

            let secondsLeft = 16;
            const timerId = setInterval(() => {
                updateVirtualLog("Iniciando motor em " + secondsLeft + "s...");
                if (secondsLeft-- <= 0) {
                    clearInterval(timerId);
                    updateVirtualLog("🚀 ACIONANDO ENGINE...");
                    startBrainEngine();
                }
            }, 1000);

        } catch (e) { console.log("Erro UI: " + e); }
    });
});

// --- MOTOR ---
function startBrainEngine() {
    const mod = Process.findModuleByName("libqplay.so");
    if (mod) {
        updateVirtualLog("✅ Motor Detectado! Mapeando via SYMBOLS...");
        initBot(mod);
    } else {
        updateVirtualLog("❌ libqplay.so não encontrada.");
    }
}

