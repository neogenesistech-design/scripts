                // 3. PAINEL INFERIOR E GAVETA DE MENU
                // ========================================================================
                const mainBarLayout = classLoader.LinearLayout.$new(mainActivity); mainBarLayout.setOrientation(classLoader.LinearLayout.VERTICAL.value); mainBarLayout.setGravity(Gravity.CENTER.value); mainBarLayout.setVisibility(View.GONE.value); 
                const row1 = classLoader.LinearLayout.$new(mainActivity); row1.setOrientation(classLoader.LinearLayout.HORIZONTAL.value); row1.setGravity(Gravity.CENTER.value);
                const row2 = classLoader.LinearLayout.$new(mainActivity); row2.setOrientation(classLoader.LinearLayout.HORIZONTAL.value); row2.setGravity(Gravity.CENTER.value);
                mainBarLayout.addView(row1); mainBarLayout.addView(row2);

                const bottomLayout = classLoader.LinearLayout.$new(mainActivity); const bottomParams = classLoader.LinearLayout_LayoutParams.$new(-1, -1); bottomLayout.setLayoutParams(bottomParams); bottomLayout.setGravity(Gravity.BOTTOM.value | Gravity.CENTER_HORIZONTAL.value); bottomLayout.addView(mainBarLayout);

                const topInfoTextView = classLoader.TextView.$new(mainActivity); topInfoTextView.setTextColor(classLoader.Color.WHITE.value); topInfoTextView.setShadowLayer(5, 0, 0, classLoader.Color.BLACK.value);
                const topBarLayout = classLoader.LinearLayout.$new(mainActivity); topBarLayout.setOrientation(classLoader.LinearLayout.HORIZONTAL.value); topBarLayout.setGravity(Gravity.CENTER_VERTICAL.value);
                const topLayout = classLoader.LinearLayout.$new(mainActivity); const topParams = classLoader.LinearLayout_LayoutParams.$new(-1, -1); topLayout.setLayoutParams(topParams); topLayout.setGravity(Gravity.TOP.value | Gravity.LEFT.value); 
                
                const call_hideCheats = { on() { mainBarLayout.setVisibility(View.VISIBLE.value); }, off() { mainBarLayout.setVisibility(View.GONE.value); } };
                const hideCheatsButton = createToggleButton("[ Menu ]", call_hideCheats, false); 
                
                const toggleScannerPanel = { on() { scannerPanel.setVisibility(View.VISIBLE.value); uiNeedsUpdate = true; }, off() { scannerPanel.setVisibility(View.GONE.value); } };
                const scannerMenuBtn = createToggleButton("[ Painel Scanner ]", toggleScannerPanel, false);

                topBarLayout.addView(hideCheatsButton.view); topBarLayout.addView(scannerMenuBtn.view); topBarLayout.addView(topInfoTextView);
                topLayout.addView(topBarLayout); topLayout.addView(scannerPanel);

                const addToggle = (row, text, callbacks, startOn = false) => { const button = createToggleButton(text, callbacks, startOn); row.addView(button.view); autoOffButtons.push(button); };
                
                addToggle(row1, "Unhit(M1)", call_unhit_m1, false); addToggle(row1, "Unhit(M2)", call_unhit_m2, false); addToggle(row1, "Anti Afk", call_antiAfk, false); addToggle(row1, "Auto Off", call_autoOFF, false);
                addToggle(row2, "Wall Hack", call_wallhack, false);
                const showAdminsButton = createToggleButton("Radar ADM", call_showAdmins, true); row2.addView(showAdminsButton.view);

                const explosionControlLayout = classLoader.LinearLayout.$new(mainActivity); explosionControlLayout.setOrientation(classLoader.LinearLayout.HORIZONTAL.value); explosionControlLayout.setGravity(Gravity.CENTER.value);
                const explosionButton = createToggleButton(`Explodir: ${explosionRadius}`, call_explode); autoOffButtons.push(explosionButton);
                const updateRadiusText = () => Java.scheduleOnMainThread(() => explosionButton.view.setText(classLoader.String.$new(`Explodir: ${explosionRadius}`)));
                const decreaseAction = () => { explosionRadius = Math.max(1, explosionRadius - 1); updateRadiusText(); }; const increaseAction = () => { explosionRadius = Math.min(100, explosionRadius + 1); updateRadiusText(); };
                explosionControlLayout.addView(createHoldButton("<", decreaseAction)); explosionControlLayout.addView(explosionButton.view); explosionControlLayout.addView(createHoldButton(">", increaseAction));
                row2.addView(explosionControlLayout);

                mainActivity.addContentView(trRootLayout, trRootParams); 
                mainActivity.addContentView(topLayout, topParams); 
                mainActivity.addContentView(bottomLayout, bottomParams);

                // ========================================================================
                // LOOP PRINCIPAL (UI e Anti-Lag)
                // ========================================================================
                setInterval(() => {
                    Java.scheduleOnMainThread(function() {
                        if (pendingAdminDisable) {
                            pendingAdminDisable = false;
                            const ctx = mainActivity.getApplicationContext();
                            Java.use("android.widget.Toast").makeText(ctx, Java.use("java.lang.String").$new('Admin Detectado. Desativando cheats.'), 0).show();
                            for (const button of autoOffButtons) { button.reset(); }
                        }
                        if (pendingAdminToastMsg) {
                            const ctx = mainActivity.getApplicationContext();
                            Java.use("android.widget.Toast").makeText(ctx, Java.use("java.lang.String").$new(pendingAdminToastMsg), 0).show();
                            pendingAdminToastMsg = null;
                        }
                        try {
                            const activeplayer = getActivePlayer();
                            if (!activeplayer.isNull()) {
                                const props = getPlayerProperties(activeplayer);
                                const infoText = ` Nome: ${props.nick} | Pos: (${props.x.toFixed(1)}, ${props.y.toFixed(1)})`;
                                topInfoTextView.setText(classLoader.String.$new(infoText));
                            }
                        } catch(e) {}

                        if (uiNeedsUpdate && refreshScannerUI) {
                            refreshScannerUI();
                            uiNeedsUpdate = false;
                        }
                    });
                }, 500);
                
                uiNeedsUpdate = true;
            } catch (uiError) {
                console.log("Falha crítica ao inflar a UI: " + uiError);
            }
        });
    });
}, 8000);
