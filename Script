let updateVirtualLog = function(msg) { console.log(msg); };

// Encapsulamos em uma função para chamar via setImmediate (melhor para Gadget)
function bootstrap() {
    Java.perform(function () {
        const ActivityThread = Java.use("android.app.ActivityThread");

        // Loop de espera: garante que a MainThread e a Activity existem
        const checkReady = setInterval(() => {
            try {
                const thread = ActivityThread.sCurrentActivityThread.value;
                if (thread && thread.mActivities.value.size() > 0) {
                    clearInterval(checkReady);
                    iniciarInterface(ActivityThread);
                }
            } catch (e) {}
        }, 500);
    });
}

function iniciarInterface(ActivityThread) {
    Java.scheduleOnMainThread(function () {
        try {
            const activity = ActivityThread.sCurrentActivityThread.value.mActivities.value.valueAt(0).activity.value;
            const metrics = activity.getResources().getDisplayMetrics();
            const screenHeight = metrics.heightPixels.value;

            const cl = {
                Gravity: Java.use("android.view.Gravity"),
                TextView: Java.use("android.widget.TextView"),
                LinearLayout: Java.use("android.widget.LinearLayout"),
                LayoutParams: Java.use("android.widget.LinearLayout$LayoutParams"),
                FrameLayout: Java.use("android.widget.FrameLayout"),
                FLayoutParams: Java.use("android.widget.FrameLayout$LayoutParams"),
                ScrollView: Java.use("android.widget.ScrollView"),
                Color: Java.use("android.graphics.Color"),
                Touch: Java.use("android.view.View$OnTouchListener"),
                Motion: Java.use("android.view.MotionEvent"),
                String: Java.use("java.lang.String"),
                Drawable: Java.use("android.graphics.drawable.GradientDrawable")
            };

            const CONF = {
                letraIcone: "T",
                menuLargura: 600,
                alturaMenu: Math.round(screenHeight * 0.40),
                corFundoMenu: "#F2050505",
                corBorda: "#00FF00"
            };

            const rootLayout = cl.FrameLayout.$new(activity);
            const dragContainer = cl.LinearLayout.$new(activity);
            dragContainer.setOrientation(1);
            
            const containerParams = cl.FLayoutParams.$new(-2, -2);
            containerParams.topMargin.value = 250; containerParams.leftMargin.value = 50;
            dragContainer.setLayoutParams(containerParams);

            const floatIcon = cl.TextView.$new(activity);
            floatIcon.setText(cl.String.$new(CONF.letraIcone));
            floatIcon.setTextColor(cl.Color.WHITE.value);
            floatIcon.setTextSize(22);
            floatIcon.setGravity(cl.Gravity.CENTER.value);
            const iconBg = cl.Drawable.$new();
            iconBg.setShape(1); 
            iconBg.setColor(cl.Color.parseColor("#CC000000")); 
            iconBg.setStroke(3, cl.Color.parseColor(CONF.corBorda)); 
            floatIcon.setBackground(iconBg);
            dragContainer.addView(floatIcon, cl.LayoutParams.$new(100, 100));

            const menuLayout = cl.LinearLayout.$new(activity);
            menuLayout.setOrientation(1);
            const menuBg = cl.Drawable.$new();
            menuBg.setCornerRadius(20); 
            menuBg.setColor(cl.Color.parseColor(CONF.corFundoMenu)); 
            menuBg.setStroke(3, cl.Color.parseColor(CONF.corBorda)); 
            menuLayout.setBackground(menuBg);
            menuLayout.setPadding(15, 15, 15, 15);

            const logTitle = cl.TextView.$new(activity);
            logTitle.setText(cl.String.$new("TERMINATOR GADGET LOG"));
            logTitle.setTextColor(cl.Color.parseColor(CONF.corBorda));
            menuLayout.addView(logTitle);

            const logScroll = cl.ScrollView.$new(activity);
            const logText = cl.TextView.$new(activity);
            logText.setText(cl.String.$new("[*] Sistema Inicializado...\n"));
            logText.setTextColor(cl.Color.WHITE.value);
            logText.setTextSize(9);
            logScroll.addView(logText);
            menuLayout.addView(logScroll, cl.LayoutParams.$new(-1, CONF.alturaMenu));

            updateVirtualLog = function(msg) {
                Java.scheduleOnMainThread(() => {
                    let lines = logText.getText().toString().split('\n');
                    if (lines.length > 22) lines.shift();
                    logText.setText(cl.String.$new(lines.join('\n') + "\n[#] " + msg));
                    logScroll.fullScroll(130);
                });
            };

            // DRAG HANDLER
            let iX=0, iY=0, itX=0, itY=0;
            floatIcon.setOnTouchListener(Java.registerClass({
                name: "com.term.Drag",
                implements: [cl.Touch],
                methods: {
                    onTouch: function (v, event) {
                        const action = event.getAction();
                        if (action === 0) { // ACTION_DOWN
                            iX = containerParams.leftMargin.value; iY = containerParams.topMargin.value;
                            itX = event.getRawX(); itY = event.getRawY();
                        } else if (action === 2) { // ACTION_MOVE
                            containerParams.leftMargin.value = iX + Math.round(event.getRawX() - itX);
                            containerParams.topMargin.value = iY + Math.round(event.getRawY() - itY);
                            dragContainer.setLayoutParams(containerParams);
                        } else if (action === 1) { // ACTION_UP
                            if (Math.abs(event.getRawX() - itX) < 15) {
                                const vis = menuLayout.getVisibility() === 0;
                                menuLayout.setVisibility(vis ? 8 : 0);
                            }
                        }
                        return true;
                    }
                }
            }).$new());

            dragContainer.addView(menuLayout, cl.LayoutParams.$new(CONF.menuLargura, -2));
            rootLayout.addView(dragContainer);
            activity.addContentView(rootLayout, cl.FLayoutParams.$new(-1, -1));

            // Dispara motor nativo
            setTimeout(startBrainEngine, 1000);

        } catch (e) { console.log("Erro UI: " + e); }
    });
}

function startBrainEngine() {
    const mod = Process.findModuleByName("libqplay.so");
    if (!mod) {
        updateVirtualLog("❌ Erro: libqplay.so não carregada.");
        return;
    }

    updateVirtualLog("✅ Base: " + mod.base);

    const OFFSETS = {
        walltile: 0x002B04AC,
        movement: 0x002A4538
    };

    try {
        // HOOK 1: WALLTILE (Observador passivo)
        Interceptor.attach(mod.base.add(OFFSETS.walltile), {
            onEnter(args) {
                // Aqui roda milhares de vezes, evite logs frequentes
            }
        });

        // HOOK 2: MOVEMENT (Ação do Player)
        Interceptor.attach(mod.base.add(OFFSETS.movement), {
            onEnter(args) {
                const actionID = args[1].toInt32();
                updateVirtualLog("👟 Movimento ID: " + actionID);
            }
        });

        updateVirtualLog("🚀 Hooks ativos via Offset!");

    } catch (err) {
        updateVirtualLog("❌ Erro Hook: " + err.message);
    }
}

// Inicia o processo
setImmediate(bootstrap);
