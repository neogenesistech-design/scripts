                        Java.use("android.widget.Toast").makeText(context, Java.use("java.lang.String").$new(pendingAdminToastMsg), 0).show();
                        pendingAdminToastMsg = null;
                    }

                    // 2. Atualiza Posição do Info Text
                    try {
                        const activeplayer = activeplayerPtr.readPointer();
                        if (!activeplayer.isNull()) {
                            const props = getPlayerProperties(activeplayer);
                            const infoText = ` Nome: ${props.nick} | Pos: (${props.x.toFixed(1)}, ${props.y.toFixed(1)})`;
                            topInfoTextView.setText(classLoader.String.$new(infoText));
                        }
