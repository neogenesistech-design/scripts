            setInterval(() => {
                Java.scheduleOnMainThread(function() {
                    // 1. Processa Ações de Admin Pendentes (Fim do lag do Admin)
                    if (pendingAdminDisable) {
                        pendingAdminDisable = false;
                        var context = Java.use("android.app.ActivityThread").currentApplication().getApplicationContext();
                        Java.use("android.widget.Toast").makeText(context, Java.use("java.lang.String").$new('Admin Detectado. Desativando cheats.'), 0).show();
                        for (const button of autoOffButtons) { button.reset(); }
                    }
                    if (pendingAdminToastMsg) {
