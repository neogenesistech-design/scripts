// ========================================================================
// TERMINATOR V88.8 - DUAL OFFSET HOOK (WALLTILE + MOVEMENT)
// ========================================================================

let updateVirtualLog = function(msg) { console.log(msg); };

Java.perform(function () {
    function getClassLoader() {
        return {
            Gravity: Java.use("android.view.Gravity"),
            TextView: Java.use("android.widget.TextView"),
            LinearLayout: Java.use("android.widget.LinearLayout"),
            LinearLayout_LayoutParams: Java.use("android.widget.LinearLayout$LayoutParams"),
            FrameLayout: Java.use("android.widget.FrameLayout"),
            FrameLayout_LayoutParams: Java.use("android.widget.FrameLayout$LayoutParams"),
            ScrollView: Java.use("android.widget.ScrollView"),
            Color: Java.use("android.graphics.Color"),
            ActivityThread: Java.use("android.app.ActivityThread"),
            View_OnTouchListener: Java.use("android.view.View$OnTouchListener"),
            MotionEvent: Java.use("android.view.MotionEvent"),
            String: Java.use("java.lang.String"),
            View: Java.use("android.view.View"),
            DisplayMetrics: Java.use("android.util.DisplayMetrics"),
            GradientDrawable: Java.use("android.graphics.drawable.GradientDrawable")
        };
    }

    function getMainActivity(classLoader) { 
        const activityThread = classLoader.ActivityThread.sCurrentActivityThread.value;
        const activityClientRecord = Java.cast(
            activityThread.mActivities.value.valueAt(0),
            Java.use("android.app.ActivityThread$ActivityClientRecord")
        );
        return activityClientRecord.activity.value;
    }

    Java.scheduleOnMainThread(function () {
        try {
            const c = getClassLoader();
            const act = getMainActivity(c);
            const metrics = act.getResources().getDisplayMetrics();
            const screenHeight = metrics.heightPixels.value;

            const CONF = {
                letraIcone: "T",
                menuLargura: 600,
                alturaMenu: Math.round(screenHeight * 0.45),
                corFundoMenu: "#F2050505",
                corBorda: "#00FF00"
            };

            const rootLayout = c.FrameLayout.$new(act);
            const dragContainer = c.LinearLayout.$new(act);
            dragContainer.setOrientation(c.LinearLayout.VERTICAL.value);
            
            const containerParams = c.FrameLayout_LayoutParams.$new(-2, -2);
            containerParams.gravity.value = c.Gravity.TOP.value | c.Gravity.LEFT.value;
            containerParams.leftMargin.value = 50;
            containerParams.topMargin.value = 300;
            dragContainer.setLayoutParams(containerParams);

            const floatIcon = c.TextView.$new(act);
            floatIcon.setText(c.String.$new(CONF.letraIcone));
            floatIcon.setTextColor(c.Color.WHITE.value);
            floatIcon.setTextSize(22.0); 
            floatIcon.setGravity(c.Gravity.CENTER.value);
            const iconBg = c.GradientDrawable.$new();
            iconBg.setShape(1); 
            iconBg.setColor(c.Color.parseColor("#CC000000")); 
            iconBg.setStroke(3, c.Color.parseColor(CONF.corBorda)); 
            floatIcon.setBackground(iconBg);
            dragContainer.addView(floatIcon, c.LinearLayout_LayoutParams.$new(100, 100));

            const menuLayout = c.LinearLayout.$new(act);
            menuLayout.setOrientation(c.LinearLayout.VERTICAL.value);
            const menuBg = c.GradientDrawable.$new();
            menuBg.setCornerRadius(20.0); 
            menuBg.setColor(c.Color.parseColor(CONF.corFundoMenu)); 
            menuBg.setStroke(3, c.Color.parseColor(CONF.corBorda)); 
            menuLayout.setBackground(menuBg);
            menuLayout.setPadding(20, 20, 20, 20); 

            const logTitle = c.TextView.$new(act);
            logTitle.setText(c.String.$new("TERMINATOR SYSTEM LOGS"));
            logTitle.setTextColor(c.Color.parseColor(CONF.corBorda));
            menuLayout.addView(logTitle);

            const logScroll = c.ScrollView.$new(act);
            const logText = c.TextView.$new(act);
            logText.setText(c.String.$new("[*] UI Pronta...\n"));
            logText.setTextColor(c.Color.WHITE.value);
            logText.setTextSize(10.0);
            logScroll.addView(logText);
            menuLayout.addView(logScroll, c.LinearLayout_LayoutParams.$new(-1, CONF.alturaMenu));

            updateVirtualLog = function(msg) {
                Java.scheduleOnMainThread(() => {
                    let current = logText.getText().toString();
                    let lines = current.split('\n');
                    if (lines.length > 25) lines.shift();
                    lines.push("[#] " + msg);
                    logText.setText(c.String.$new(lines.join('\n')));
                    logScroll.post(Java.registerClass({
                        name: "Scroll_" + Math.random(),
                        implements: [Java.use("java.lang.Runnable")],
                        methods: { run: function() { logScroll.fullScroll(130); } }
                    }).$new());
                });
            };

            let iX=0, iY=0, itX=0, itY=0;
            floatIcon.setOnTouchListener(Java.registerClass({
                name: "DragHandler_" + Math.random(),
                implements: [c.View_OnTouchListener],
                methods: {
                    onTouch: function (v, event) {
                        const action = event.getAction();
                        if (action === c.MotionEvent.ACTION_DOWN.value) {
                            iX = containerParams.leftMargin.value; iY = containerParams.topMargin.value;
                            itX = event.getRawX(); itY = event.getRawY();
                        } else if (action === c.MotionEvent.ACTION_MOVE.value) {
                            containerParams.leftMargin.value = iX + Math.round(event.getRawX() - itX);
                            containerParams.topMargin.value = iY + Math.round(event.getRawY() - itY);
                            dragContainer.setLayoutParams(containerParams);
                        } else if (action === c.MotionEvent.ACTION_UP.value) {
                            if (Math.abs(event.getRawX() - itX) < 15) {
                                const vis = menuLayout.getVisibility() === c.View.VISIBLE.value;
                                menuLayout.setVisibility(vis ? c.View.GONE.value : c.View.VISIBLE.value);
                            }
                        }
                        return true;
                    }
                }
            }).$new());

            dragContainer.addView(menuLayout, c.LinearLayout_LayoutParams.$new(CONF.menuLargura, -2));
            rootLayout.addView(dragContainer);
            act.addContentView(rootLayout, c.FrameLayout_LayoutParams.$new(-1, -1));

            setTimeout(() => startBrainEngine(), 3000);

        } catch (e) { console.log("Erro UI: " + e); }
    });
});

// --- ENGINE ---
function startBrainEngine() {
    const mod = Process.findModuleByName("libqplay.so");
    if (!mod) {
        updateVirtualLog("❌ lib não encontrada");
        return;
    }
    updateVirtualLog("✅ BASE: " + mod.base);
    initBot(mod);
}

// --- OFFSET INJECTION ---
function initBot(mod) {
    const base = mod.base;

    // OFFSETS DO SEU DUMP
    const OFFSETS = {
        walltile: 0x002B04AC,
        movement: 0x002A4538
    };

    const addrWall = base.add(OFFSETS.walltile);
    const addrMove = base.add(OFFSETS.movement);

    updateVirtualLog("📍 walltile: " + addrWall);
    updateVirtualLog("📍 movement: " + addrMove);

    try {
        // HOOK 1: WALLTILE (Colisões)
        Interceptor.attach(addrWall, {
            onEnter(args) {
                // updateVirtualLog("🔥 walltile"); 
            }
        });

        // HOOK 2: MOVEMENT ACTION (Movimento do Player)
        Interceptor.attach(addrMove, {
            onEnter(args) {
                // args[1] é o 'int' da direção ou ação (param_1 no seu dump)
                const action = args[1].toInt32();
                updateVirtualLog("👟 Movimento ID: " + action);
            }
        });

        updateVirtualLog("🚀 Hooks aplicados com sucesso!");

    } catch (e) {
        updateVirtualLog("❌ erro: " + e.message);
    }
}
