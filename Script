// ========================================================================
// TERMINATOR V88.3 - FULL VISUAL LOADER + LOG TERMINAL
// ========================================================================

// Redirecionamento Global de Logs para a UI
let updateVirtualLog = function(msg) { console.log(msg); };

// --- 1. DELAY INICIAL PARA ESTABILIDADE ---
setTimeout(() => {
    Java.perform(function () {
        
        function getClassLoader() {
            return {
                Gravity: Java.use("android.view.Gravity"),
                TextView: Java.use("android.widget.TextView"),
                LinearLayout: Java.use("android.widget.LinearLayout"),
                LinearLayout_LayoutParams: Java.use("android.widget.LinearLayout$LayoutParams"),
                FrameLayout: Java.use("android.widget.FrameLayout"),
                FrameLayout_LayoutParams: Java.use("android.widget.FrameLayout$LayoutParams"),
                ScrollView: Java.use("android.widget.ScrollView"),
                Color: Java.use("android.graphics.Color"),
                ActivityThread: Java.use("android.app.ActivityThread"),
                View_OnTouchListener: Java.use("android.view.View$OnTouchListener"),
                MotionEvent: Java.use("android.view.MotionEvent"),
                String: Java.use("java.lang.String"),
                View: Java.use("android.view.View"),
                GradientDrawable: Java.use("android.graphics.drawable.GradientDrawable")
            };
        }

        function getMainActivity(classLoader) { 
            const activityThread = classLoader.ActivityThread.sCurrentActivityThread.value;
            const activityClientRecord = Java.cast(activityThread.mActivities.value.valueAt(0), Java.use("android.app.ActivityThread$ActivityClientRecord"));
            return activityClientRecord.activity.value;
        }

        Java.scheduleOnMainThread(function () {
            try {
                const cl = getClassLoader();
                const mainActivity = getMainActivity(cl);
                const metrics = mainActivity.getResources().getDisplayMetrics();
                const screenWidth = metrics.widthPixels.value;
                const screenHeight = metrics.heightPixels.value;

                const CONF = {
                    letraIcone: "T",
                    menuLargura: 600,
                    alturaMenu: Math.round(screenHeight * 0.45),
                    corFundo: "#EE101010",
                    corBorda: "#00FF00"
                };

                const rootLayout = cl.FrameLayout.$new(mainActivity);
                const dragContainer = cl.LinearLayout.$new(mainActivity);
                dragContainer.setOrientation(cl.LinearLayout.VERTICAL.value);
                
                const containerParams = cl.FrameLayout_LayoutParams.$new(-2, -2);
                containerParams.gravity.value = cl.Gravity.TOP.value | cl.Gravity.LEFT.value;
                containerParams.leftMargin.value = 50;
                containerParams.topMargin.value = 200;
                dragContainer.setLayoutParams(containerParams);

                // --- ÍCONE FLUTUANTE ---
                const floatIcon = cl.TextView.$new(mainActivity);
                floatIcon.setText(cl.String.$new(CONF.letraIcone));
                floatIcon.setTextColor(cl.Color.parseColor("#FFFFFF"));
                floatIcon.setTextSize(22);
                floatIcon.setGravity(cl.Gravity.CENTER.value);
                const iconBg = cl.GradientDrawable.$new();
                iconBg.setShape(1);
                iconBg.setColor(cl.Color.parseColor("#CC000000"));
                iconBg.setStroke(3, cl.Color.parseColor(CONF.corBorda));
                floatIcon.setBackground(iconBg);
                dragContainer.addView(floatIcon, cl.LinearLayout_LayoutParams.$new(100, 100));

                // --- JANELA DO MENU ---
                const menuLayout = cl.LinearLayout.$new(mainActivity);
                menuLayout.setOrientation(cl.LinearLayout.VERTICAL.value);
                const menuBg = cl.GradientDrawable.$new();
                menuBg.setCornerRadius(20);
                menuBg.setColor(cl.Color.parseColor(CONF.corFundo));
                menuBg.setStroke(3, cl.Color.parseColor(CONF.corBorda));
                menuLayout.setBackground(menuBg);
                menuLayout.setPadding(15, 15, 15, 15);
                menuLayout.setVisibility(cl.View.GONE.value);

                // --- ÁREA DE LOGS (O CORAÇÃO DO DEBUG) ---
                const logTitle = cl.TextView.$new(mainActivity);
                logTitle.setText(cl.String.$new("--- SYSTEM LOGS ---"));
                logTitle.setTextColor(cl.Color.parseColor("#00FF00"));
                logTitle.setTextSize(12);
                menuLayout.addView(logTitle);

                const logScroll = cl.ScrollView.$new(mainActivity);
                const logText = cl.TextView.$new(mainActivity);
                logText.setText(cl.String.$new("[*] Aguardando Inicialização...\n"));
                logText.setTextColor(cl.Color.parseColor("#FFFFFF"));
                logText.setTextSize(10);
                logScroll.addView(logText);
                menuLayout.addView(logScroll, cl.LinearLayout_LayoutParams.$new(-1, CONF.alturaMenu));

                // Função para atualizar o terminal na tela
                updateVirtualLog = function(msg) {
                    Java.scheduleOnMainThread(() => {
                        let current = logText.getText().toString();
                        let newLog = current + "[#] " + msg + "\n";
                        // Mantém apenas as últimas 20 linhas para não pesar
                        let lines = newLog.split('\n');
                        if(lines.length > 25) lines.shift();
                        logText.setText(cl.String.$new(lines.join('\n')));
                        logScroll.fullScroll(130); // Scroll para o fim (FOCUS_DOWN)
                    });
                };

                // --- LÓGICA DE ARRASTAR ---
                let iX=0, iY=0, itX=0, itY=0;
                floatIcon.setOnTouchListener(Java.registerClass({
                    name: "com.term.Drag",
                    implements: [cl.View_OnTouchListener],
                    methods: {
                        onTouch: function (v, event) {
                            const action = event.getAction();
                            if (action === cl.MotionEvent.ACTION_DOWN.value) {
                                iX = containerParams.leftMargin.value; iY = containerParams.topMargin.value;
                                itX = event.getRawX(); itY = event.getRawY();
                            } else if (action === cl.MotionEvent.ACTION_MOVE.value) {
                                containerParams.leftMargin.value = iX + Math.round(event.getRawX() - itX);
                                containerParams.topMargin.value = iY + Math.round(event.getRawY() - itY);
                                dragContainer.setLayoutParams(containerParams);
                            } else if (action === cl.MotionEvent.ACTION_UP.value) {
                                if (Math.abs(event.getRawX() - itX) < 15) {
                                    const vis = menuLayout.getVisibility() === cl.View.VISIBLE.value;
                                    menuLayout.setVisibility(vis ? cl.View.GONE.value : cl.View.VISIBLE.value);
                                }
                            }
                            return true;
                        }
                    }
                }).$new());

                dragContainer.addView(menuLayout, cl.LinearLayout_LayoutParams.$new(CONF.menuLargura, -2));
                rootLayout.addView(dragContainer);
                mainActivity.addContentView(rootLayout, cl.FrameLayout_LayoutParams.$new(-1, -1));

                updateVirtualLog("Visual Loader Pronto!");
                iniciarFaseDoBot(); // Chama a lógica do bot após a UI estar pronta

            } catch (e) {
                console.log("Erro UI: " + e);
            }
        });
    });
}, 3000);

// --- 2. LÓGICA DO MOTOR (BOT V88.3) ---
function iniciarFaseDoBot() {
    updateVirtualLog("Aguardando libqplay.so...");
    
    const checkInterval = setInterval(() => {
        const mod = Process.findModuleByName("libqplay.so");
        if (mod) {
            clearInterval(checkInterval);
            updateVirtualLog("Motor Encontrado! Hooking...");
            try {
                initBot(mod);
            } catch (err) {
                updateVirtualLog("ERRO CRÍTICO: " + err.message);
            }
        }
    }, 1000);
}

function initBot(mod) {
    // Endereços e Exports
    const setPropsAddr = mod.findExportByName("_ZN10TServerNPC13setPropertiesERK7TString");
    const drawAddr = mod.findExportByName("_ZN10TServerNPC4drawEP7TPlayer");
    const addDrawAddr = mod.findExportByName("_ZN7TPlayer13addDrawObjectEP12TLevelObject");
    const movementAction = new NativeFunction(mod.findExportByName("_ZN7TPlayer14movementActionEi"), 'void', ['pointer', 'int']);
    const setDir = new NativeFunction(mod.findExportByName("_ZN7TPlayer6setdirEi"), 'void', ['pointer', 'int']);
    const startAnimation = new NativeFunction(mod.findExportByName("_ZN11TGaniObject14startAnimationERK7TString"), 'void', ['pointer', 'pointer']);
    const curanisExp = mod.enumerateExports().find(e => e.name === "curanis");

    if (!curanisExp || !addDrawAddr) {
        updateVirtualLog("Falha: Exports não encontrados.");
        return;
    }

    const ptrIdle = curanisExp.address.add(0x00);
    const ptrWalk = curanisExp.address.add(0x08);

    // Variáveis de Controle
    const trackedItems = new Map();
    let meuPtr = null, alvoPtr = null, levelPtrReal = null;
    let isReviving = false, estavaAndando = false;
    let miniPath = [];
    let ultimoTickBot = 0;

    const TICK_INTERVAL = 40;
    const DIST_STOP_ITEM = 0.4;
    const LOOT_DIST_INSTANT = 10.0;

    updateVirtualLog("Sistema de Hooks injetado com sucesso.");

    // Hook Principal de Render/Lógica
    Interceptor.attach(addDrawAddr, {
        onEnter(args) {
            const pObj = args[1];
            if (this.context.x0.equals(pObj)) {
                meuPtr = pObj;
                let now = Date.now();
                if (now - ultimoTickBot >= TICK_INTERVAL) {
                    ultimoTickBot = now;
                    
                    // Lógica Simplificada de Chaining para Teste Visual
                    let bestItem = null;
                    let minD = 999;
                    trackedItems.forEach((item) => {
                        if (item.distGlobal < minD) { minD = item.distGlobal; bestItem = item; }
                    });

                    if (bestItem && minD < 1.5) {
                        updateVirtualLog("Loot coletado: " + bestItem.name);
                        trackedItems.delete(bestItem.ptr);
                    }
                }
            } else if (!alvoPtr) {
                // Tenta achar o Cacty
                try {
                    const namePtr = pObj.add(664).readPointer();
                    const name = namePtr.add(8).readCString(namePtr.readInt());
                    if (name === "Cacty") {
                        alvoPtr = pObj;
                        updateVirtualLog("Alvo Bloqueado: Cacty");
                    }
                } catch(e){}
            }
        }
    });

    // Monitor de Morte
    Interceptor.attach(mod.findExportByName("_ZN7TPlayer7setDeadEb"), {
        onEnter(args) {
            if (args[1].toInt32() === 1 && meuPtr && args[0].equals(meuPtr)) {
                updateVirtualLog("MORTE DETECTADA!");
                // Aqui entraria a função de reviver que já temos
            }
        }
    });
}
