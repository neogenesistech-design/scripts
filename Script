function initBot(mod) {
    updateVirtualLog("Mapeando memória via Enumerate...");

    // --- DICIONÁRIO DE ENDEREÇOS ---
    let addr = {
        setProps: null,
        draw: null,
        removeNPC: null,
        movementAction: null,
        setDir: null,
        walltile: null,
        startAnimation: null,
        addDraw: null,
        loadLevel: null,
        setDead: null,
        setFeatures: null,
        curanis: null
    };

    // --- VARREDURA DE EXPORTS (MÉTODO RESILIENTE) ---
    const exports = mod.enumerateExports();
    for (let i = 0; i < exports.length; i++) {
        let name = exports[i].name;
        let p = exports[i].address;

        if (name.includes("setPropertiesERK7TString")) addr.setProps = p;
        else if (name.includes("TServerNPC4drawEP7TPlayer")) addr.draw = p;
        else if (name.includes("removeNPCEi")) addr.removeNPC = p;
        else if (name.includes("movementActionEi")) addr.movementAction = p;
        else if (name.includes("setdirEi")) addr.setDir = p;
        else if (name.includes("walltileEdd")) addr.walltile = p;
        else if (name.includes("startAnimationERK7TString")) addr.startAnimation = p;
        else if (name.includes("addDrawObjectEP12TLevelObject")) addr.addDraw = p;
        else if (name.includes("loadStartLevelEb")) addr.loadLevel = p;
        else if (name.includes("setDeadEb")) addr.setDead = p;
        else if (name.includes("setEnabledFeaturesEi")) addr.setFeatures = p;
        else if (name === "curanis") addr.curanis = p;
    }

    // --- VALIDAÇÃO CRÍTICA ---
    if (!addr.addDraw || !addr.curanis || !addr.movementAction) {
        updateVirtualLog("Erro: Falha ao localizar símbolos via Enumerate.");
        // Log de debug para você ver o que está disponível no seu Logcat/Terminal
        console.log("[DEBUG] addDraw: " + addr.addDraw + " | curanis: " + addr.curanis);
        return;
    }

    // --- DEFINIÇÃO DAS FUNÇÕES NATIVAS ---
    const movementAction = new NativeFunction(addr.movementAction, 'void', ['pointer', 'int']);
    const setDir         = new NativeFunction(addr.setDir, 'void', ['pointer', 'int']);
    const walltile       = new NativeFunction(addr.walltile, 'int', ['pointer', 'double', 'double']);
    const startAnimation = new NativeFunction(addr.startAnimation, 'void', ['pointer', 'pointer']);
    const loadStartLevel = new NativeFunction(addr.loadLevel, 'void', ['pointer', 'int']);
    const setDead        = new NativeFunction(addr.setDead, 'void', ['pointer', 'int']);
    const setFeatures    = addr.setFeatures ? new NativeFunction(addr.setFeatures, 'void', ['pointer', 'int']) : null;

    const ptrIdle = addr.curanis.add(0x00); 
    const ptrWalk = addr.curanis.add(0x08); 

    // --- VARIÁVEIS DE ESTADO DO BOT ---
    const trackedItems = new Map();
    let levelPtrReal = null, meuPtr = null, alvoPtr = null;
    let miniPath = [], lastTargetX = -1, lastTargetY = -1;
    let estavaAndando = false, targetLocked = false, isReviving = false;
    let ultimoTickBot = 0, ultimaTelemetria = 0, mapSent = false, tempoUltimoCalculo = 0;

    // Configurações Técnicas
    const LOOT_DIST_INSTANT = 10.0;
    const LOOT_DIST_MAX     = 100.0;
    const LOOT_DELAY_FAR    = 5.0;
    const ANTI_GHOST_TIME   = 22.0;
    const DIST_STOP_ALVO    = 2.5;
    const DIST_STOP_ITEM    = 0.4;
    const TICK_INTERVAL     = 40;
    const OFFSET_Y_MAPA     = 0.5;
    const LOOK_AHEAD_RADIUS = 0.65;
    const ZONA_MORTA_DIAGONAL = 0.30;
    const SEARCH_LIMIT      = 2000;

    const visitadoAStar = new Float32Array(4096);

    // [O restante da lógica A*, MinHeap, e Hooks de Render permanecem iguais, 
    // apenas garanta que eles usem os endereços do objeto 'addr']

    // Exemplo de Hook corrigido usando o objeto addr:
    Interceptor.attach(addr.addDraw, {
        onEnter(args) {
            const pObj = args[1];
            if (this.context.x0.equals(pObj)) {
                meuPtr = pObj;
                let now = Date.now();
                if (now - ultimoTickBot >= TICK_INTERVAL) {
                    ultimoTickBot = now;
                    tickBot(); // Sua função de movimento
                }
            } else if (!alvoPtr) {
                try {
                    const namePtr = pObj.add(664).readPointer();
                    if (namePtr.readInt() > 0 && namePtr.add(8).readCString(namePtr.readInt()) === "Cacty") {
                        alvoPtr = pObj;
                        updateVirtualLog("Alvo Bloqueado: Cacty");
                    }
                } catch(e) {}
            }
        }
    });

    if (addr.setProps) {
        Interceptor.attach(addr.setProps, {
            onEnter: function(args) {
                // ... lógica de parsing de string do item ...
            }
        });
    }

    if (addr.setDead) {
        Interceptor.attach(addr.setDead, {
            onEnter: function(args) {
                if (args[1].toInt32() === 1 && meuPtr && args[0].equals(meuPtr)) {
                    updateVirtualLog("Status: MORTO. Revivendo...");
                    isReviving = true;
                    // Lógica de ressurreição usando loadStartLevel e setFeatures
                }
            }
        });
    }

    updateVirtualLog("Hooks Injetados via Enumerate!");
}
