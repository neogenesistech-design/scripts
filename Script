function logNative(msg) {
    Java.perform(function() {
        var Log = Java.use("android.util.Log");
        Log.d("MOTOR", msg);
    });
}

setTimeout(function() {
    Java.perform(function () {
        logNative("Iniciando injeção visual na camada DecorView...");

        Java.choose("android.app.Activity", {
            onMatch: function (activity) {
                logNative("Activity encontrada: " + activity.getClass().getName());

                Java.scheduleOnMainThread(function () {
                    try {
                        var Color = Java.use("android.graphics.Color");
                        var TextView = Java.use("android.widget.TextView");
                        var FrameLayout = Java.use("android.widget.FrameLayout");
                        var LinearLayout = Java.use("android.widget.LinearLayout");
                        var GradientDrawable = Java.use("android.graphics.drawable.GradientDrawable");
                        var Gravity = Java.use("android.view.Gravity");
                        var MotionEvent = Java.use("android.view.MotionEvent");
                        var String = Java.use("java.lang.String");
                        var View = Java.use("android.view.View");
                        var ViewGroup = Java.use("android.view.ViewGroup");

                        var metrics = activity.getResources().getDisplayMetrics();
                        var screenWidth = metrics.widthPixels.value;
                        var screenHeight = metrics.heightPixels.value;
                        var iconSize = 130;

                        // --- 1. MENU PRINCIPAL ---
                        var menuLayout = LinearLayout.$new(activity);
                        menuLayout.setOrientation(1); 
                        
                        var menuBg = GradientDrawable.$new();
                        menuBg.setShape(0); 
                        menuBg.setCornerRadius(40.0); 
                        menuBg.setColor(Color.parseColor("#E6151515")); 
                        menuBg.setStroke(4, Color.parseColor("#00FF00")); 
                        menuLayout.setBackground(menuBg);
                        menuLayout.setPadding(50, 50, 50, 50);
                        menuLayout.setVisibility(View.GONE.value); 

                        var menuParams = FrameLayout.LayoutParams.$new(screenWidth - 200, -2);
                        menuParams.gravity = Gravity.CENTER.value; 
                        menuLayout.setLayoutParams(menuParams);

                        var titulo = TextView.$new(activity);
                        titulo.setText(String.$new("⚡ GRAAL HACKS ⚡"));
                        titulo.setTextColor(Color.parseColor("#00FF00"));
                        titulo.setGravity(Gravity.CENTER.value);
                        titulo.setTextSize(20.0);
                        menuLayout.addView(titulo);

                        // --- 2. ÍCONE FLUTUANTE ---
                        var floatIcon = TextView.$new(activity);
                        floatIcon.setText(String.$new("G")); 
                        floatIcon.setTextColor(Color.WHITE.value);
                        floatIcon.setTextSize(26.0);
                        floatIcon.setGravity(Gravity.CENTER.value);

                        var iconBg = GradientDrawable.$new();
                        iconBg.setShape(1); 
                        iconBg.setColor(Color.parseColor("#CC000000")); 
                        iconBg.setStroke(5, Color.parseColor("#00FF00")); 
                        floatIcon.setBackground(iconBg);

                        var iconParams = FrameLayout.LayoutParams.$new(iconSize, iconSize);
                        iconParams.leftMargin = parseInt((screenWidth / 2) - (iconSize / 2));
                        iconParams.topMargin = parseInt((screenHeight / 2) - (iconSize / 2));
                        floatIcon.setLayoutParams(iconParams);

                        var initialX = 0, initialY = 0, initialTouchX = 0, initialTouchY = 0;

                        floatIcon.setOnTouchListener(Java.registerClass({
                            name: "com.graal.DragIcon_" + Math.random().toString(36).substr(2),
                            implements: [Java.use("android.view.View$OnTouchListener")],
                            methods: {
                                onTouch: function (v, event) {
                                    var action = event.getAction();
                                    if (action === MotionEvent.ACTION_DOWN.value) {
                                        initialX = iconParams.leftMargin.value;
                                        initialY = iconParams.topMargin.value;
                                        initialTouchX = event.getRawX();
                                        initialTouchY = event.getRawY();
                                        return true;
                                    } else if (action === MotionEvent.ACTION_MOVE.value) {
                                        var newX = initialX + parseInt(event.getRawX() - initialTouchX);
                                        var newY = initialY + parseInt(event.getRawY() - initialTouchY);
                                        
                                        if (newX < 0) newX = 0;
                                        if (newY < 0) newY = 0;
                                        if (newX > screenWidth - iconSize) newX = screenWidth - iconSize;
                                        if (newY > screenHeight - iconSize - 100) newY = screenHeight - iconSize - 100;

                                        iconParams.leftMargin = newX;
                                        iconParams.topMargin = newY;
                                        v.setLayoutParams(iconParams);
                                        return true;
                                    } else if (action === MotionEvent.ACTION_UP.value) {
                                        var diffX = Math.abs(event.getRawX() - initialTouchX);
                                        var diffY = Math.abs(event.getRawY() - initialTouchY);
                                        
                                        if (diffX < 15 && diffY < 15) {
                                            var isVisible = menuLayout.getVisibility() === View.VISIBLE.value;
                                            menuLayout.setVisibility(isVisible ? View.GONE.value : View.VISIBLE.value);
                                        }
                                        return true;
                                    }
                                    return false;
                                }
                            }
                        }).$new());

                        // --- 3. INJEÇÃO FORÇADA NA CAMADA SUPREMA (DecorView) ---
                        var rootLayout = FrameLayout.$new(activity);
                        rootLayout.addView(menuLayout); 
                        rootLayout.addView(floatIcon);  

                        var rootParams = FrameLayout.LayoutParams.$new(-1, -1);
                        
                        // Pegamos a janela absoluta do Android
                        var window = activity.getWindow();
                        var decorView = window.getDecorView();
                        // 16908290 é o ID fixo do android.R.id.content (A raiz visual)
                        var androidContent = decorView.findViewById(16908290); 
                        
                        if (androidContent != null) {
                            var contentGroup = Java.cast(androidContent, ViewGroup);
                            contentGroup.addView(rootLayout, rootParams);
                            
                            // A MÁGICA: Joga a nossa camada por cima dos gráficos do jogo
                            rootLayout.bringToFront(); 
                            
                            logNative("Sucesso absoluto: Interface atropelou os graficos e foi desenhada.");
                        } else {
                            logNative("ERRO: Nao achou a raiz do Android.");
                        }

                    } catch (e) {
                        logNative("ERRO UI: " + e.toString());
                    }
                });
            },
            onComplete: function () {
                logNative("Varredura concluida.");
            }
        });
    });
}, 5000);
