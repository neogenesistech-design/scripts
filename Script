            const btnSave = classLoader.TextView.$new(mainActivity);
            btnSave.setText(classLoader.String.$new("SAVE TXT")); btnSave.setTextColor(classLoader.Color.WHITE.value); btnSave.setBackgroundColor(COLOR_SAVE); btnSave.setPadding(PADDING, PADDING, PADDING, PADDING); btnSave.setLayoutParams(btnLP);
            btnSave.setOnClickListener(Java.registerClass({
                name: "com.example.SaveScanClick" + Math.random().toString(36).substring(2), implements: [Java.use("android.view.View$OnClickListener")],
                methods: {
                    onClick(v) {
                        if (!selectedTargetName) { showToast("Selecione na lista primeiro."); return; }
                        Java.perform(() => {
                            try {
                                const pkgName = ActivityThread.currentApplication().getApplicationContext().getPackageName();
                                const FileOutputStream = Java.use("java.io.FileOutputStream");
                                const filePath = Java.use("android.os.Environment").getExternalStorageDirectory().getAbsolutePath() + "/Android/data/" + pkgName + "/saved_functions.txt";
                                let fos = FileOutputStream.$new(filePath, true); 
                                fos.write(Java.use("java.lang.String").$new(saveCounter + ". " + selectedTargetName + "\n").getBytes());
