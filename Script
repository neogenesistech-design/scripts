            const listContainer = classLoader.LinearLayout.$new(mainActivity);
            listContainer.setOrientation(classLoader.LinearLayout.VERTICAL.value);
            scrollView.addView(listContainer);
            scannerPanel.addView(scrollView);

            refreshScannerUI = function() {
                Java.scheduleOnMainThread(() => {
                    listContainer.removeAllViews();
                    
                    if (scanMode === 1) {
                        const loadingTv = classLoader.TextView.$new(mainActivity);
                        loadingTv.setText(classLoader.String.$new("...Calibrando (Fique Parado)..."));
                        loadingTv.setTextColor(classLoader.Color.YELLOW.value);
                        listContainer.addView(loadingTv);
                        return;
                    }

                    if (smartListLogs.length === 0) {
                        const emptyTv = classLoader.TextView.$new(mainActivity);
                        emptyTv.setText(classLoader.String.$new("Nenhuma ação capturada."));
                        emptyTv.setTextColor(classLoader.Color.GRAY.value);
                        listContainer.addView(emptyTv);
                        return;
                    }

                    for (let i = 0; i < smartListLogs.length; i++) {
                        const funcName = smartListLogs[i];
                        const itemTv = classLoader.TextView.$new(mainActivity);
                        
                        let displayName = funcName.length > 35 ? funcName.substring(0, 35) + "..." : funcName;
                        itemTv.setText(classLoader.String.$new(displayName));
                        
                        if (funcName === selectedTargetName) {
                            itemTv.setBackgroundColor(COLOR_SELECTED);
                            itemTv.setTextColor(classLoader.Color.BLACK.value);
                        } else {
                            itemTv.setBackgroundColor(classLoader.Color.TRANSPARENT.value);
                            itemTv.setTextColor(classLoader.Color.YELLOW.value);
                        }
                        
                        itemTv.setPadding(PADDING, PADDING, PADDING, PADDING);
                        
                        itemTv.setOnClickListener(Java.registerClass({
