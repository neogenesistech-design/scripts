/* SCRIPT DE TESTE COM DELAY - HELLO WORLD TOAST */

setTimeout(function() {
    Java.perform(function() {
        console.log("[*] Iniciando execução após delay...");

        Java.scheduleOnMainThread(function() {
            try {
                var Toast = Java.use("android.widget.Toast");
                var String = Java.use("java.lang.String");
                var ActivityThread = Java.use("android.app.ActivityThread");
                
                // Tenta pegar o contexto. Se falhar, tentamos outra forma.
                var app = ActivityThread.currentApplication();
                if (app == null) {
                    console.log("[-] Erro: Application ainda é nula.");
                    return;
                }
                
                var context = app.getApplicationContext();
                var message = String.$new("Frida Ativo! Delay Funcionou.");
                
                var toast = Toast.makeText(context, message, 1);
                toast.show();
                
                console.log("[*] Toast disparado com sucesso!");
            } catch (err) {
                console.log("[-] Erro no script: " + err);
            }
        });
    });
}, 5000); // 5 segundos de espera
